<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'SteamCoupons' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <a href="/" class="nav-logo">
    <span class="logo-icon">⟨S⟩</span>
    <span>SteamCoupons</span>
  </a>
  <div class="nav-links">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard">Dashboard</a>
      <% if (user.role === 'admin') { %><a href="/admin" class="admin-link">Admin</a><% } %>
      <span class="nav-user">@<%= user.username %></span>
      <a href="/logout" class="btn-nav-logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register" class="btn-nav-register">Register</a>
    <% } %>
  </div>
</nav>
<%- body %>
<footer class="footer">
  <p>© 2025 SteamCoupons &nbsp;·&nbsp; <span class="mono">Educational Platform</span></p>
</footer>
</body>
</html>
