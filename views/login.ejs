<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — SteamCoupons</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
<nav class="navbar">
  <a href="/" class="nav-logo"><span class="logo-icon">⟨S⟩</span><span>SteamCoupons</span></a>
  <div class="nav-links"><a href="/register" class="btn-nav-register">Register</a></div>
</nav>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-icon">🎮</div>
      <h1>Welcome Back</h1>
      <p>Sign in to access your coupons</p>
    </div>
    <% if (error) { %>
    <div class="alert-error"><span>⚠</span> <%= error %></div>
    <% } %>
    <form action="/login" method="POST" class="auth-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Enter username" required autocomplete="username">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter password" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn-submit">Sign In</button>
    </form>
    <div class="auth-footer">
      Don't have an account? <a href="/register">Register here</a>
    </div>
    <div class="auth-demo mono">
      demo: john_doe / user123
    </div>
  </div>
</div>
<footer class="footer"><p>© 2025 SteamCoupons</p></footer>
</body>
</html>
